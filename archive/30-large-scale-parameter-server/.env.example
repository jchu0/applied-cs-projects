# Large-Scale Parameter Server Configuration
# Copy this file to .env and update values as needed

# Server Configuration
PS_HOST=0.0.0.0
PS_PORT=50051
PS_NUM_SHARDS=4
PS_REPLICATION_FACTOR=2

# Redis (Parameter Storage)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_MAX_MEMORY=1gb

# Etcd (Coordination)
ETCD_HOST=localhost
ETCD_PORT=2379
ETCD_PREFIX=/paramserver

# PostgreSQL (Metadata)
DATABASE_URL=postgresql://paramserver:paramserver@localhost:5432/paramserver

# Zookeeper (Optional, for HA)
ZOOKEEPER_HOSTS=localhost:2181
ZOOKEEPER_ENABLED=false

# gRPC Configuration
GRPC_MAX_MESSAGE_SIZE=104857600  # 100MB
GRPC_KEEPALIVE_TIME=30
GRPC_KEEPALIVE_TIMEOUT=10

# Synchronization
SYNC_MODE=async  # sync, async, bounded_staleness
STALENESS_BOUND=100  # for bounded_staleness mode
AGGREGATION_STRATEGY=mean  # mean, sum, weighted_mean

# Compression
COMPRESSION_ENABLED=true
COMPRESSION_ALGORITHM=lz4  # lz4, zstd, blosc

# Memory Management
MEMORY_LIMIT_GB=8
SPILL_TO_DISK=true
SPILL_PATH=/tmp/paramserver

# Checkpointing
CHECKPOINT_ENABLED=true
CHECKPOINT_INTERVAL=600  # seconds
CHECKPOINT_PATH=./checkpoints

# Monitoring
PROMETHEUS_PORT=9090
GPU_MONITORING_ENABLED=false
LOG_LEVEL=INFO

# MPI (for distributed training)
MPI_ENABLED=false
MPI_NUM_WORKERS=4
