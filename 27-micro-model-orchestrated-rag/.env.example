# Micro-Model Orchestrated RAG Configuration
# Copy this file to .env and update values as needed

# LLM Fallback API Keys (for hybrid mode)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Vector Store
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# Small Language Models
SLM_CACHE_DIR=./models
SLM_DEVICE=cpu  # cpu, cuda, mps

# Query Router Model
QUERY_ROUTER_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Retriever Model
RETRIEVER_MODEL=sentence-transformers/multi-qa-MiniLM-L6-cos-v1

# Reranker Model
RERANKER_MODEL=cross-encoder/ms-marco-TinyBERT-L-2-v2

# Generator Model (small)
GENERATOR_MODEL=microsoft/phi-2
GENERATOR_MAX_TOKENS=256

# Redis Cache (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_ENABLED=false

# Tracing
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=microrag
TRACING_ENABLED=false

# Guardrails
GUARDRAILS_ENABLED=true
MAX_INPUT_LENGTH=4096

# Performance
BATCH_SIZE=8
NUM_WORKERS=4

# Logging
LOG_LEVEL=INFO
