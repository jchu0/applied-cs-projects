# Streaming Platform Configuration
# Copy this file to .env and update values as needed

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Schema Registry
SCHEMA_REGISTRY_URL=http://localhost:8081

# Flink Configuration
FLINK_JOBMANAGER_HOST=localhost
FLINK_JOBMANAGER_PORT=8081
FLINK_PARALLELISM=4

# Producer Settings
PRODUCER_ACKS=all
PRODUCER_RETRIES=3
PRODUCER_BATCH_SIZE=16384
PRODUCER_LINGER_MS=5

# Consumer Settings
CONSUMER_GROUP_ID=streaming-app
CONSUMER_AUTO_OFFSET_RESET=earliest
CONSUMER_ENABLE_AUTO_COMMIT=false
CONSUMER_MAX_POLL_RECORDS=500

# Windowing
WINDOW_SIZE_SECONDS=60
WINDOW_SLIDE_SECONDS=10
LATE_DATA_ALLOWED_SECONDS=300

# Checkpointing
CHECKPOINT_INTERVAL_MS=60000
CHECKPOINT_TIMEOUT_MS=600000
CHECKPOINT_PATH=file:///tmp/flink-checkpoints

# Logging
LOG_LEVEL=INFO
