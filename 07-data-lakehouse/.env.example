# Data Lakehouse Configuration
# Copy this file to .env and update values as needed

# Spark Configuration
SPARK_MASTER=spark://localhost:7077
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g
SPARK_EXECUTOR_CORES=2

# MinIO / S3 Storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=lakehouse

# Delta Lake
DELTA_LOG_PATH=s3a://lakehouse/delta
DELTA_CHECKPOINT_INTERVAL=10

# Hive Metastore (PostgreSQL)
METASTORE_DB_URL=postgresql://hive:hive@localhost:5432/metastore

# Data Quality (Great Expectations)
GE_DATA_DOCS_PATH=./great_expectations/data_docs
GE_EXPECTATIONS_PATH=./great_expectations/expectations

# Processing
PARTITION_COLUMNS=year,month,day
COMPACTION_THRESHOLD_MB=1024
VACUUM_RETENTION_HOURS=168

# Logging
LOG_LEVEL=INFO
