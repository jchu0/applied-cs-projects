# Model Routing Layer Configuration
# Copy this file to .env and update values as needed

# LLM Provider API Keys
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
COHERE_API_KEY=your-cohere-key

# LLM Endpoints (for self-hosted models)
LLAMA_ENDPOINT=http://localhost:8080
MISTRAL_ENDPOINT=http://localhost:8081

# Redis (Rate Limiting & Caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# PostgreSQL (Quota & Analytics)
DATABASE_URL=postgresql://router:router@localhost:5432/modelrouter
DATABASE_POOL_SIZE=10

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_TOKENS_PER_MINUTE=100000
RATE_LIMIT_REQUESTS_PER_DAY=10000

# Cost Controls
MAX_COST_PER_REQUEST=1.00
MAX_COST_PER_USER_PER_DAY=100.00
COST_TRACKING_ENABLED=true

# Load Balancing
LOAD_BALANCER_STRATEGY=round_robin  # round_robin, least_connections, weighted
HEALTH_CHECK_INTERVAL=30
TIMEOUT_SECONDS=120

# Caching
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE_MB=1024

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=9090
JAEGER_ENDPOINT=http://localhost:14268/api/traces
LOG_LEVEL=INFO

# Security
API_KEY_HEADER=X-API-Key
JWT_SECRET=your-jwt-secret-change-in-production

# HTTP-layer hardening (src/modelrouter/security.py; stdlib, opt-in)
# Comma-separated valid API keys. Unset/empty disables auth (health + docs stay open).
API_KEYS=
# In-process sliding-window request cap per key/IP (0 disables). Default 120.
RATE_LIMIT_PER_MINUTE=120
# Per-request timeout in seconds (0 disables). Default 30.
REQUEST_TIMEOUT_SECONDS=30
